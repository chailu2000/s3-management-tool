{
    "compilerOptions": {
        "types": [
            "node",
            "vscode"
        ],
        "module": "commonjs",
        "target": "ES2020",
        "outDir": "./out",
        "lib": [
            "es2020"
        ],
        "sourceMap": true,
        "rootDir": "src",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true
    },
    "exclude": [
        "node_modules",
        ".vscode-test",
        "**/*.test.ts",
        "**/*.spec.ts"
    ]
}